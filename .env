# ── Lokale Entwicklung (SQLite, kein Redis, E-Mail im Terminal) ──

SECRET_KEY=local-dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite statt PostgreSQL (für lokalen Test)
USE_SQLITE=True

# Redis / RQ (nicht nötig bei USE_SQLITE=True, wird ignoriert)
REDIS_URL=redis://localhost:6379

# E-Mail (web.de)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.web.de
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=test.rueckmeldung@web.de
EMAIL_HOST_PASSWORD=u2p9D*Vmj,#WeEY
DEFAULT_FROM_EMAIL=test.rueckmeldung@web.de

# Frontend URL für E-Mail Links
FRONTEND_URL=http://127.0.0.1:5500

# Cookies
COOKIE_SECURE=False
COOKIE_SAMESITE=Lax

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
